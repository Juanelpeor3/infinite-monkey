---
import { translations, type Lang } from "../i18n/translations";

interface Props {
    lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = translations[lang];
---

<footer
    class="text-center py-8 mt-12 text-xs font-sans text-[#b0926a] tracking-widest uppercase"
>
    {t.footer.madeBy} <a
        href="https://github.com/Juanelpeor3"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#8b6f47] underline underline-offset-2 hover:text-[#6b5237] transition-colors"
        >Juanelpeor3</a
    >
</footer>
