---
import { translations, type Lang } from "../i18n/translations";

interface Props {
    chars?: string;
    sourceId?: string;
    lang?: Lang;
}

const { chars, sourceId, lang = "es" } = Astro.props;
const t = translations[lang].wordSearch;
const strings = JSON.stringify({
    noChars: t.noChars,
    zeroMatches: t.zeroMatches,
    match: t.match,
    matches: t.matches,
});
---

<div class="flex flex-col gap-3" data-ws-strings={strings} data-lang={lang}>
    <div class="flex items-center gap-3">
        <input
            id="word-search-input"
            type="text"
            placeholder={t.placeholder}
            data-source-id={sourceId ?? ""}
            class="flex-1 bg-[#f5f0e8] border border-[#c9b99a] rounded-lg px-4 py-2 font-mono text-sm text-[#1a1a1a] placeholder-[#b0926a] focus:outline-none focus:border-[#8b6f47]"
        />
        <span
            id="word-search-count"
            class="text-xs font-sans text-[#8b6f47] whitespace-nowrap min-w-15 text-right"
        ></span>
    </div>

    {
        sourceId ? (
            <pre
                id="word-search-highlight"
                aria-hidden="true"
                class="hidden bg-[#1e1e1e] text-[#d4d4d4] px-4 sm:px-6 py-4 sm:py-5 rounded-lg text-base sm:text-lg font-mono whitespace-pre-wrap w-full flex-1 h-56 sm:h-72 lg:h-80 overflow-y-auto leading-relaxed"
            />
        ) : (
            <pre
                id="word-search-output"
                class="bg-[#1e1e1e] text-[#d4d4d4] px-4 sm:px-6 py-4 sm:py-5 rounded-lg text-base sm:text-lg font-mono whitespace-pre-wrap w-full flex-1 h-56 sm:h-72 lg:h-80 overflow-y-auto leading-relaxed"
                data-chars={chars}
            >
                {chars || t.noChars}
            </pre>
        )
    }
</div>

<script>
    const input = document.getElementById(
        "word-search-input",
    ) as HTMLInputElement;
    const countEl = document.getElementById("word-search-count") as HTMLElement;

    const container = input.closest("[data-ws-strings]") as HTMLElement;
    const strings = JSON.parse(container.dataset.wsStrings!);

    const sourceId = input.dataset.sourceId || null;
    const sourceEl = sourceId ? document.getElementById(sourceId) : null;
    const highlightEl = document.getElementById(
        "word-search-highlight",
    ) as HTMLElement | null;
    const outputEl = document.getElementById(
        "word-search-output",
    ) as HTMLElement | null;

    const staticRaw = outputEl?.dataset.chars ?? "";

    function getText() {
        return sourceEl ? (sourceEl.textContent ?? "") : staticRaw;
    }

    input.addEventListener("input", () => {
        const query = input.value.trim();
        const text = getText();

        if (!query) {
            countEl.textContent = "";
            if (sourceEl) {
                sourceEl.classList.remove("hidden");
                highlightEl?.classList.add("hidden");
            } else if (outputEl) {
                outputEl.innerHTML = escapeHtml(text) || strings.noChars;
            }
            return;
        }

        const matches = text.match(new RegExp(escapeRegex(query), "gi"));
        const count = matches ? matches.length : 0;

        if (query.toLowerCase() === "shakespeare" && count > 0)
            triggerShakespeare();

        countEl.textContent =
            count === 0
                ? strings.zeroMatches
                : `${count} ${count !== 1 ? strings.matches : strings.match}`;

        const highlighted = escapeHtml(text).replace(
            new RegExp(escapeRegex(escapeHtml(query)), "gi"),
            (m) =>
                `<mark class="bg-[#8b6f47] text-white rounded px-0.5">${m}</mark>`,
        );

        if (sourceEl && highlightEl) {
            highlightEl.innerHTML = highlighted;
            sourceEl.classList.add("hidden");
            highlightEl.classList.remove("hidden");
        } else if (outputEl) {
            outputEl.innerHTML = highlighted;
        }
    });

    const lang = (container.dataset.lang || "es") as "es" | "en";
    const shakespeareMsgs = {
        es: {
            title: "¡Lo consiguió!",
            msg: "El mono ha escrito SHAKESPEARE.\nEl teorema es real.",
            close: "Haz clic para cerrar",
        },
        en: {
            title: "It happened!",
            msg: "The monkey typed SHAKESPEARE.\nThe theorem is real.",
            close: "Click to close",
        },
    };

    function triggerShakespeare() {
        if (document.getElementById("shakespeare-overlay")) return;
        const sm = shakespeareMsgs[lang];
        const overlay = document.createElement("div");
        overlay.id = "shakespeare-overlay";
        overlay.style.cssText =
            "position:fixed;inset:0;background:rgba(0,0,0,0.88);display:flex;align-items:center;justify-content:center;z-index:9999;cursor:pointer;";
        overlay.innerHTML = `
            <div style="text-align:center;color:white;font-family:serif;padding:2rem;max-width:420px">
                <div style="font-size:3.5rem;margin-bottom:1rem">🎉🐒🎉</div>
                <h2 style="font-size:2rem;margin-bottom:1rem;color:#f5d000;font-family:serif">${sm.title}</h2>
                <p style="font-size:1.1rem;color:#d4d4d4;white-space:pre-line;line-height:1.6">${sm.msg}</p>
                <p style="margin-top:2rem;font-size:0.75rem;color:#666;font-family:sans-serif">${sm.close}</p>
            </div>`;
        overlay.addEventListener("click", () => overlay.remove());
        document.body.appendChild(overlay);
        spawnConfetti();
    }

    function spawnConfetti() {
        const style = document.createElement("style");
        style.textContent =
            "@keyframes confettiFall{to{transform:translateY(110vh) rotate(720deg);opacity:0}}";
        document.head.appendChild(style);
        const colors = [
            "#f5d000",
            "#8b6f47",
            "#d4d4d4",
            "#ff6b6b",
            "#4ecdc4",
            "#fff",
        ];
        for (let i = 0; i < 80; i++) {
            setTimeout(() => {
                const c = document.createElement("div");
                const size = 4 + Math.random() * 8;
                c.style.cssText = `position:fixed;top:-10px;left:${Math.random() * 100}%;width:${size}px;height:${size}px;background:${colors[Math.floor(Math.random() * colors.length)]};border-radius:${Math.random() > 0.5 ? "50%" : "2px"};pointer-events:none;z-index:10000;animation:confettiFall ${1 + Math.random() * 2}s ease-in ${Math.random() * 0.5}s forwards;`;
                document.body.appendChild(c);
                c.addEventListener("animationend", () => c.remove());
            }, Math.random() * 800);
        }
    }

    function escapeHtml(str: string) {
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    function escapeRegex(str: string) {
        return str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }
</script>
