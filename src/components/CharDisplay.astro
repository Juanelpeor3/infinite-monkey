---
import WordSearch from "./WordSearch.astro";

interface Props {
    // Static mode (MonkeyBot)
    chars?: string;
    total?: number;
    // Dynamic mode (BeTheMonkey)
    charsId?: string;
    badgeId?: string;
}

const {
    chars,
    total,
    charsId = "allChars",
    badgeId = "charBadge",
} = Astro.props;

const isStatic = chars !== undefined;
---

<div class="w-full lg:w-1/2 flex flex-col gap-3">
    <div class="flex items-center justify-between">
        <h2 class="text-lg sm:text-xl text-[#333] font-semibold">
            Generated characters
        </h2>
        {
            isStatic ? (
                <span class="text-xs font-sans bg-[#8b6f47] text-white px-3 py-1 rounded-full">
                    {total}
                </span>
            ) : (
                <span
                    id={badgeId}
                    class="text-xs font-sans bg-[#8b6f47] text-white px-3 py-1 rounded-full"
                >
                    0
                </span>
            )
        }
    </div>

    {
        isStatic ? (
            total === 0 ? (
                <div class="bg-[#1e1e1e] text-[#666] px-4 sm:px-6 py-4 sm:py-5 rounded-lg text-base sm:text-lg font-mono h-56 sm:h-72 lg:h-80 flex items-center justify-center text-center">
                    No characters yet. The bot will start soon.
                </div>
            ) : (
                <WordSearch chars={chars} />
            )
        ) : (
            <>
                <WordSearch sourceId={charsId} />
                <pre
                    id={charsId}
                    aria-label="All generated characters"
                    class="bg-[#1e1e1e] text-[#d4d4d4] px-4 sm:px-6 py-4 sm:py-5 rounded-lg text-base sm:text-lg font-mono whitespace-pre-wrap w-full flex-1 h-56 sm:h-72 lg:h-80 overflow-y-auto leading-relaxed"
                />
            </>
        )
    }
</div>
