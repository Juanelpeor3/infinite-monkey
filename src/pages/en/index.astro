---
import Layout from "../../layouts/Layout.astro";
import { translations } from "../../i18n/translations";

const lang = "en" as const;
const t = translations[lang];
---

<Layout lang={lang}>
    <main
        class="max-w-175 mx-auto mt-15 px-6 font-serif text-[#222] leading-[1.7]"
    >
        <h1 class="text-[2.2rem] text-center mb-10 text-[#1a1a1a]">
            {t.home.title}
        </h1>

        <section class="mb-8">
            <p
                class="text-[1.2rem] bg-[#f5f0e8] border-l-4 border-[#8b6f47] px-5 py-4 rounded"
                set:html={t.home.intro}
            />
        </section>

        <section class="mb-8">
            <h2 class="text-[1.4rem] mt-10 mb-3 text-[#333]">
                {t.home.howTitle}
            </h2>
            <p set:html={t.home.how1} />
            <p class="mt-4" set:html={t.home.how2} />
        </section>

        <section class="mb-8">
            <h2 class="text-[1.4rem] mt-10 mb-3 text-[#333]">
                {t.home.exampleTitle}
            </h2>
            <p set:html={t.home.example1} />
            <code
                class="block bg-[#1e1e1e] text-[#d4d4d4] px-5 py-3 rounded-md text-base my-3 tracking-wider font-mono"
            >
                (1/28)¹¹ ≈ 1 in 17,537,720,524,288,000
            </code>
            <p set:html={t.home.example2} />
        </section>

        <div class="flex gap-4 justify-center mt-12 mb-15">
            <a
                href="/en/bethemonkey"
                class="block w-fit bg-[#8b6f47] hover:bg-[#6b5237] text-white px-8 py-3.5 rounded-lg text-[1.1rem] font-sans no-underline transition-colors"
            >
                {t.home.ctaMonkey}
            </a>
            <a
                href="/en/monkey-bot"
                class="block w-fit bg-white hover:bg-[#f5f0e8] text-[#8b6f47] border border-[#8b6f47] px-8 py-3.5 rounded-lg text-[1.1rem] font-sans no-underline transition-colors"
            >
                {t.home.ctaBot}
            </a>
        </div>
    </main>
</Layout>
